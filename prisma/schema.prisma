generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS
// ============================================
model User {
  id                String    @id @default(uuid()) @db.Uuid
  name              String    @db.VarChar(100)
  email             String    @unique @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  whatsapp          String?   @db.VarChar(20)
  youtubeChannel    String?   @map("youtube_channel") @db.VarChar(500)
  avatarUrl         String?   @map("avatar_url") @db.VarChar(500)
  googleId          String?   @unique @map("google_id") @db.VarChar(200)
  role              String    @default("client") @db.VarChar(20) // client, admin, staff
  staffRole         String?   @map("staff_role") @db.VarChar(30) // editor, designer, manager, operator
  level             String    @default("bronze") @db.VarChar(20) // bronze, silver, gold, diamond
  ordersCount       Int       @default(0) @map("orders_count")
  streakCount       Int       @default(0) @map("streak_count")
  lastLoginAt       DateTime? @map("last_login_at")
  points            Int       @default(0)
  referralCode      String?   @unique @map("referral_code") @db.VarChar(20)
  referredBy        String?   @map("referred_by") @db.Uuid
  referrer          User?     @relation("ReferredUsers", fields: [referredBy], references: [id])
  referralLevel     Int       @default(1) @map("referral_level") // 1=direct, 2=indirect
  staffToken        String?   @unique @map("staff_token") @db.VarChar(100)
  countryCode       String    @default("BD") @map("country_code") @db.VarChar(5)
  locale            String    @default("bn") @db.VarChar(10)
  currency          String    @default("BDT") @db.VarChar(5)
  isFreeTrialUsed   Boolean   @default(false) @map("is_free_trial_used")
  isVerified        Boolean   @default(false) @map("is_verified")
  emailVerified     Boolean   @default(false) @map("email_verified")
  phoneVerified     Boolean   @default(false) @map("phone_verified")
  isActive          Boolean   @default(true) @map("is_active")
  badges            Json      @default("[]") @db.JsonB
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  orders           Order[]
  ratings          Rating[]
  sentMessages     ChatMessage[] @relation("SenderMessages")
  referralEarnings ReferralEarning[] @relation("ReferrerEarnings")
  referralWithdrawals ReferralWithdrawal[]
  subscriptions    Subscription[]
  coupons          CouponUsage[]
  referredUsers    User[]        @relation("ReferredUsers")
  assignedOrders   Order[]       @relation("AssignedStaff")
  blogPosts      BlogPost[]
  blogComments   BlogComment[]
  announcements  Announcement[]  @relation("AnnouncementCreator")
  notifications  Notification[]
  supportTickets SupportTicket[]
  ticketReplies  TicketReply[]
  assignedTickets SupportTicket[] @relation("TicketStaff")

  @@map("users")
}

// ============================================
// SERVICES (seed data)
// ============================================
model Service {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(100)
  slug          String    @unique @db.VarChar(100)
  shortDesc     String?   @map("short_desc") @db.VarChar(300)
  fullDesc      String?   @map("full_desc") @db.Text
  thumbnailUrl  String?   @map("thumbnail_url") @db.VarChar(500)
  videoUrl      String?   @map("video_url") @db.VarChar(500)
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  isFreeTrial   Boolean   @default(false) @map("is_free_trial")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  packages ServicePackage[]

  @@map("services")
}

model ServicePackage {
  id          String   @id @default(uuid()) @db.Uuid
  serviceId   String   @map("service_id") @db.Uuid
  name        String   @db.VarChar(50) // basic, standard, premium
  price       Decimal  @db.Decimal(10, 2)
  deliveryHrs Int      @map("delivery_hrs")
  revisions   Int      @default(1)
  features    Json     @db.JsonB // ["Cut+Trim", "Noise Remove"]
  isPopular   Boolean  @default(false) @map("is_popular")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_packages")
}

// ============================================
// ORDERS
// ============================================
model Order {
  id               String    @id @default(uuid()) @db.Uuid
  orderNumber      String    @unique @map("order_number") @db.VarChar(20)
  userId           String    @map("user_id") @db.Uuid
  serviceType      String    @map("service_type") @db.VarChar(50)
  packageName      String?   @map("package_name") @db.VarChar(50)
  packagePrice     Decimal   @map("package_price") @db.Decimal(10, 2)
  expressDelivery  Boolean   @default(false) @map("express_delivery")
  expressFee       Decimal   @default(0) @map("express_fee") @db.Decimal(10, 2)
  totalPriceBdt    Decimal   @map("total_price_bdt") @db.Decimal(10, 2)
  totalPriceLocal  Decimal?  @map("total_price_local") @db.Decimal(10, 2)
  currency         String    @default("BDT") @db.VarChar(5)
  advanceAmount    Decimal?  @map("advance_amount") @db.Decimal(10, 2)
  remainingAmount  Decimal?  @map("remaining_amount") @db.Decimal(10, 2)
  isFreeTrial      Boolean   @default(false) @map("is_free_trial")
  status           String    @default("pending_payment") @db.VarChar(30)
  // statuses: pending_payment, paid_pending_assign, assigned, in_progress, in_review, revision, delivered, cancelled
  assignedTo       String?   @map("assigned_to") @db.Uuid
  assignedStaff    User?      @relation("AssignedStaff", fields: [assignedTo], references: [id])
  driveLink        String?   @map("drive_link") @db.VarChar(500)
  fileUrl          String?   @map("file_url") @db.VarChar(500)
  deliveryUrl      String?   @map("delivery_url") @db.VarChar(500)
  instructions     String?   @db.Text
  internalNotes    String?   @map("internal_notes") @db.Text
  subscriptionId   String?   @map("subscription_id") @db.Uuid
  subscription      Subscription? @relation("SubscriptionOrders", fields: [subscriptionId], references: [id])
  couponId         String?   @map("coupon_id") @db.Uuid
  discountAmount   Decimal   @default(0) @map("discount_amount") @db.Decimal(10, 2)
  deliveryDeadline DateTime? @map("delivery_deadline")
  deliveredAt      DateTime? @map("delivered_at")
  countryCode      String    @default("BD") @map("country_code") @db.VarChar(5)
  paymentGateway   String?   @map("payment_gateway") @db.VarChar(30)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user      User          @relation(fields: [userId], references: [id])
  ratings   Rating[]
  messages  ChatMessage[]
  payments  Payment[]
  details   OrderDetail[]

  @@index([userId])
  @@index([status])
  @@index([serviceType])
  @@index([createdAt])
  @@index([assignedTo])
  @@index([countryCode])
  @@map("orders")
}

model OrderDetail {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  details   Json     @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_details")
}

// ============================================
// SUBSCRIPTIONS
// ============================================
model Subscription {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  planName            String    @map("plan_name") @db.VarChar(30)
  planPriceBdt        Decimal   @map("plan_price_bdt") @db.Decimal(10, 2)
  planPriceLocal      Decimal?  @map("plan_price_local") @db.Decimal(10, 2)
  currency            String    @default("BDT") @db.VarChar(5)
  status              String    @default("pending") @db.VarChar(20)
  creditsTotal        Int?      @map("credits_total")
  creditsRemaining    Int?      @map("credits_remaining")
  billingDay          Int       @default(1) @map("billing_day")
  billingPreferences  Json?     @map("billing_preferences") @db.JsonB
  billingCycleStart   DateTime? @map("billing_cycle_start")
  nextBillingDate     DateTime? @map("next_billing_date")
  stripeSubId         String?   @map("stripe_sub_id") @db.VarChar(200)
  cancelledAt         DateTime? @map("cancelled_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id])
  orders Order[] @relation("SubscriptionOrders")

  @@map("subscriptions")
}

// ============================================
// PAYMENTS
// ============================================
model Payment {
  id             String    @id @default(uuid()) @db.Uuid
  orderId        String?   @map("order_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  amountBdt      Decimal   @map("amount_bdt") @db.Decimal(10, 2)
  amountLocal    Decimal?  @map("amount_local") @db.Decimal(10, 2)
  currency       String    @default("BDT") @db.VarChar(5)
  method         String?   @db.VarChar(30) // sslcommerz, stripe, paypal, bkash
  transactionId  String?   @map("transaction_id") @db.VarChar(200)
  gatewayRef     String?   @map("gateway_ref") @db.VarChar(200)
  stripePiId     String?   @map("stripe_pi_id") @db.VarChar(200)
  status         String    @default("pending") @db.VarChar(20)
  webhookData    Json?     @map("webhook_data") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at")

  order Order? @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("payments")
}

// ============================================
// RATINGS
// ============================================
model Rating {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  stars       Int
  comment     String?  @db.Text
  allowPublic Boolean  @default(false) @map("allow_public")
  isApproved  Boolean  @default(false) @map("is_approved")
  createdAt   DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@map("ratings")
}

// ============================================
// CHAT MESSAGES
// ============================================
model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  message   String?  @db.Text
  fileUrl   String?  @map("file_url") @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation("SenderMessages", fields: [senderId], references: [id])

  @@index([orderId])
  @@map("chat_messages")
}

// ============================================
// COUPONS
// ============================================
model Coupon {
  id           String    @id @default(uuid()) @db.Uuid
  code         String    @unique @db.VarChar(30)
  type         String    @db.VarChar(20) // percentage, fixed
  discount     Decimal   @db.Decimal(10, 2)
  serviceType  String?   @map("service_type") @db.VarChar(50)
  countryCode  String?   @map("country_code") @db.VarChar(5)
  usageLimit   Int?
  usedCount    Int       @default(0) @map("used_count")
  perUserLimit Int       @default(1) @map("per_user_limit")
  expiresAt    DateTime? @map("expires_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid()) @db.Uuid
  couponId  String   @map("coupon_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orderId   String?  @map("order_id") @db.Uuid
  usedAt    DateTime @default(now()) @map("used_at")

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("coupon_usage")
}

// ============================================
// REFERRAL EARNINGS (2-level)
// ============================================
model ReferralEarning {
  id          String    @id @default(uuid()) @db.Uuid
  referrerId  String    @map("referrer_id") @db.Uuid
  refereeId   String    @map("referee_id") @db.Uuid
  orderId     String    @map("order_id") @db.Uuid
  level       Int       @default(1) // 1=direct, 2=indirect
  percentage  Decimal?  @db.Decimal(5, 2)
  amountBdt   Decimal   @map("amount_bdt") @db.Decimal(10, 2)
  status      String    @default("pending") @db.VarChar(20) // pending, cleared, withdrawn
  clearedAt   DateTime? @map("cleared_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  referrer User @relation("ReferrerEarnings", fields: [referrerId], references: [id])

  @@index([referrerId])
  @@map("referral_earnings")
}

model ReferralWithdrawal {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  amount      Decimal   @db.Decimal(10, 2)
  bkashNumber String    @map("bkash_number") @db.VarChar(20)
  status      String    @default("pending") @db.VarChar(20)
  adminNote   String?   @map("admin_note") @db.Text
  paidAt      DateTime? @map("paid_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("referral_withdrawals")
}

// ============================================
// ANNOUNCEMENTS
// ============================================
model Announcement {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(200)
  content     String    @db.Text
  type        String    @default("info") // info, warning, success, maintenance
  text        String?   @db.Text // legacy banner text
  textBn      String?   @map("text_bn") @db.Text
  linkUrl     String?   @map("link_url") @db.VarChar(500)
  linkText    String?   @map("link_text") @db.VarChar(100)
  bgColor     String    @default("#6366F1") @map("bg_color") @db.VarChar(20)
  countryCode String?   @map("country_code") @db.VarChar(5)
  isActive    Boolean   @default(true) @map("is_active")
  startsAt    DateTime  @default(now())
  expiresAt   DateTime? @map("expires_at")
  createdBy   String    @db.Uuid @map("created_by")
  creator     User      @relation("AnnouncementCreator", fields: [createdBy], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt

  @@map("announcements")
}

// ============================================
// PAGE BUILDER
// ============================================
model PageSection {
  id         String   @id @default(uuid()) @db.Uuid
  pageSlug   String   @map("page_slug") @db.VarChar(100)
  sectionKey String   @map("section_key") @db.VarChar(100)
  content    String   @db.Text
  locale     String   @default("en") @db.VarChar(10)
  updatedBy  String?  @map("updated_by") @db.Uuid
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@unique([pageSlug, sectionKey, locale])
  @@index([pageSlug, locale])
  @@map("page_sections")
}

// ============================================
// BLOG
// ============================================
model BlogPost {
  id            String    @id @default(uuid()) @db.Uuid
  slug          String    @unique
  title         String    @db.VarChar(200)
  excerpt       String?   @db.Text
  content       String    @db.Text
  coverImage    String?
  authorId      String?   @db.Uuid
  author        User?     @relation(fields: [authorId], references: [id])
  category      String?   @db.VarChar(50)
  tags          String[]  @default([])
  status        String    @default("draft")
  isPublished   Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  readTimeMins  Int       @default(5)
  viewsCount    Int       @default(0)
  likesCount    Int       @default(0)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  comments BlogComment[]

  @@map("blog_posts")
  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([category])
}

model BlogComment {
  id        String    @id @default(uuid()) @db.Uuid
  postId    String    @db.Uuid
  post      BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String    @db.Uuid
  author    User      @relation(fields: [authorId], references: [id])
  content   String    @db.Text
  isApproved Boolean  @default(false)
  createdAt DateTime  @default(now())

  @@map("blog_comments")
  @@index([postId])
  @@index([authorId])
}

// ============================================
// AUDIT LOGS
// ============================================
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  entity    String?  @db.VarChar(50)
  entityId  String?  @map("entity_id") @db.Uuid
  oldData   Json?    @map("old_data") @db.JsonB
  newData   Json?    @map("new_data") @db.JsonB
  ipAddress String?  @map("ip_address") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// ============================================
// NOTIFICATIONS (Day 10)
// ============================================
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(200)
  message   String   @db.Text
  type      String   @default("info") @db.VarChar(30) // info, success, warning, order_update, payment, promo
  linkUrl   String?  @map("link_url") @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================
// NEWSLETTER SUBSCRIBERS (Day 12)
// ============================================
model NewsletterSubscriber {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @unique @db.VarChar(255)
  name      String?   @db.VarChar(100)
  source    String    @default("website") @db.VarChar(30) // website, popup, footer, admin
  isActive  Boolean   @default(true) @map("is_active")
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")

  @@index([email])
  @@map("newsletter_subscribers")
}

// ============================================
// SUPPORT TICKETS (Day 13)
// ============================================
model SupportTicket {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  subject     String    @db.VarChar(200)
  message     String    @db.Text
  status      String    @default("open") @db.VarChar(20) // open, in_progress, resolved, closed
  priority    String    @default("medium") @db.VarChar(20) // low, medium, high, urgent
  assignedTo  String?   @map("assigned_to") @db.Uuid
  assignedStaff User?   @relation("TicketStaff", fields: [assignedTo], references: [id])
  lastReplyAt DateTime? @map("last_reply_at")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user    User             @relation(fields: [userId], references: [id])
  replies TicketReply[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model TicketReply {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  message   String   @db.Text
  isStaff   Boolean  @default(false) @map("is_staff")
  createdAt DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_replies")
}